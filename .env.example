# Claves de IA (Gemini y Copilot fallback)
GEMINI_API_KEY=tu-clave-de-gemini
COPILOT_GITHUB_TOKEN=tu-token-opcional-fallback

# Configuración de Supabase (Frontend)
VITE_SUPABASE_URL=https://tu-proyecto.supabase.co
VITE_SUPABASE_ANON_KEY=tu-clave-anonima

# Configuración de Supabase (Server-side/Proxy)
# CRÍTICO: Esta clave debe ser la 'service_role' para poder consultar tokens de usuarios
SUPABASE_SERVICE_ROLE_KEY=tu-clave-service-role
