{
  "version": 2,
  "functions": {
    "api/**/*.{js,ts}": {
      "maxDuration": 60,
      "excludeFiles": "node_modules/{@github/copilot-darwin-*,@github/copilot-win32-*,@ffmpeg-installer/**,@ffprobe-installer/**,**/*.map,**/*.ts,**/*.md}"
    }
  },
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/$1"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
