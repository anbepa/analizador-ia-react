{
  "version": 2,
  "functions": {
    "api/*.js": {
      "maxDuration": 60,
      "memory": 1024,
      "includeFiles": "node_modules/@github/**"
    },
    "api/*.ts": {
      "maxDuration": 60,
      "memory": 1024,
      "includeFiles": "node_modules/@github/**"
    }
  },
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/$1"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
