{
  "version": 2,
  "functions": {
    "api/**/*.{js,ts}": {
      "maxDuration": 60,
      "excludeFiles": "**/node_modules/@github/copilot/{**/darwin-*,**/win32-*,**/linux-arm64,**/arm64,**/windows,**/mac}/**"
    }
  },
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/$1"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
